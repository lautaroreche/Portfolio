{
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11"
  },
  "dependencies": {
    "concurrently": "^9.2.0"
  },
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./portfolio_app/static/portfolio_app/css/input.css -o ./portfolio_app/static/portfolio_app/css/output.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./portfolio_app/static/portfolio_app/css/input.css -o ./portfolio_app/static/portfolio_app/css/output.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"python3 manage.py runserver\""
  }
}
